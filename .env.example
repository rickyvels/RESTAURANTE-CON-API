# =====================================================================
#  CONFIGURACION DE LA BASE DE DATOS  (version Python)
#  Copia este archivo a ".env" y pon TU cadena de conexion.
# =====================================================================

# --- OPCION A: PostgreSQL LOCAL (lo que pide la profesora) ---
# Formato: postgresql://USUARIO:CONTRASENA@localhost:5432/NOMBRE_BD
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/restaurante

# --- OPCION B: SUPABASE (en la nube, opcional) ---
# Solo descomenta esta linea (y comenta la de arriba) si quieres usar Supabase.
# La consigues en: Supabase > Project Settings > Database > Connection string (URI).
# El codigo agrega sslmode=require automaticamente cuando la URL es de Supabase.
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@db.xxxxxxxx.supabase.co:5432/postgres

# Puerto donde corre la pagina web (dejalo en 3000)
PORT=3000
